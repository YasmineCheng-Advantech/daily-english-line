[
  {
    "id": "vi-0001",
    "lang": "vi",
    "region": "north",
    "type": "phrase",
    "topic": "打招呼",
    "text": "xin chào",
    "meaning_zh": "你好（較正式）",
    "romanization": "sin chow",
    "tone_note": "chào 尾音往下降；日常也常只說「chào」+ 稱謂，不加 xin",
    "example": "Xin chào, rất vui được gặp bạn.",
    "example_zh": "你好，很高興認識你。",
    "example_rom": "sin chow, zut vui duoc gap ban",
    "grammar_point": "xin 是禮貌前綴，讓招呼更客氣"
  },
  {
    "id": "vi-0002",
    "lang": "vi",
    "region": "north",
    "type": "phrase",
    "topic": "打招呼",
    "text": "chào anh / chào chị",
    "meaning_zh": "你好（對男性 anh／女性 chị）",
    "romanization": "chow anh / chow chi",
    "tone_note": "北部 anh 收 -nh（近「anh」），不是南部的「ang」",
    "example": "Chào chị, chị khỏe không?",
    "example_zh": "姐姐你好，你好嗎？",
    "example_rom": "chow chi, chi khwe khong?",
    "grammar_point": "越南文招呼要看對方年齡性別搭配稱謂：anh(哥) / chị(姐) / em(弟妹)"
  },
  {
    "id": "vi-0003",
    "lang": "vi",
    "region": "north",
    "type": "phrase",
    "topic": "打招呼",
    "text": "khỏe không?",
    "meaning_zh": "（你）好嗎？",
    "romanization": "khwe khong?",
    "tone_note": "北部 không 的 -ng 收成清楚鼻音「khong」，嘴唇不閉起來",
    "example": "Em khỏe không?",
    "example_zh": "你（弟妹輩）好嗎？",
    "example_rom": "em khwe khong?",
    "grammar_point": "「形容詞 + không?」= 是不是...？最常用的疑問句型"
  },
  {
    "id": "vi-0004",
    "lang": "vi",
    "region": "north",
    "type": "phrase",
    "topic": "打招呼",
    "text": "khỏe, cảm ơn",
    "meaning_zh": "很好，謝謝",
    "romanization": "khwe, kam un",
    "tone_note": "kh- 是喉部摩擦音，khỏe 近「khwe」；cảm ơn 的 ơn 近「un」",
    "example": "Mình khỏe, cảm ơn bạn.",
    "example_zh": "我很好，謝謝你。",
    "example_rom": "minh khwe, kam un ban",
    "grammar_point": "cảm ơn = 謝謝；後面可直接加對方稱謂"
  },
  {
    "id": "vi-0005",
    "lang": "vi",
    "region": "north",
    "type": "word",
    "topic": "自我介紹",
    "text": "tôi",
    "meaning_zh": "我（中性、通用）",
    "romanization": "toy",
    "tone_note": "平聲，發音接近英文 toy",
    "example": "Tôi tên là Yasmine.",
    "example_zh": "我叫 Yasmine。",
    "example_rom": "toy ten la Yasmine",
    "grammar_point": "「tôi tên là + 名字」= 我叫...，自我介紹固定句"
  },
  {
    "id": "vi-0006",
    "lang": "vi",
    "region": "north",
    "type": "word",
    "topic": "自我介紹",
    "text": "tên",
    "meaning_zh": "名字",
    "romanization": "ten",
    "tone_note": "平聲，短促",
    "example": "Bạn tên là gì?",
    "example_zh": "你叫什麼名字？",
    "example_rom": "ban ten la zi?",
    "grammar_point": "gì = 什麼；「...là gì?」= ...是什麼？（北部 gi- 發 z 音）"
  },
  {
    "id": "vi-0007",
    "lang": "vi",
    "region": "north",
    "type": "phrase",
    "topic": "自我介紹",
    "text": "rất vui được gặp bạn",
    "meaning_zh": "很高興認識你",
    "romanization": "zut vui duoc gap ban",
    "tone_note": "北部 r 發成「z」音，rất → 「zut」；但 đ 仍是 d 音，được → 「duoc」",
    "example": "Rất vui được gặp bạn!",
    "example_zh": "很高興認識你！",
    "example_rom": "zut vui duoc gap ban!",
    "grammar_point": "rất = 很（放形容詞前）；được = 得以/能夠"
  },
  {
    "id": "vi-0008",
    "lang": "vi",
    "region": "north",
    "type": "phrase",
    "topic": "自我介紹",
    "text": "người Đài Loan",
    "meaning_zh": "台灣人",
    "romanization": "nguoi Dai Loan",
    "tone_note": "người 開頭 ng- 是鼻音，台灣人可先發近「ngwoi」",
    "example": "Tôi là người Đài Loan.",
    "example_zh": "我是台灣人。",
    "example_rom": "toy la nguoi Dai Loan",
    "grammar_point": "「là + 名詞」= 是...；người + 國名 = ...國人"
  },
  {
    "id": "vi-0009",
    "lang": "vi",
    "region": "north",
    "type": "phrase",
    "topic": "打招呼",
    "text": "tạm biệt",
    "meaning_zh": "再見",
    "romanization": "tam biet",
    "tone_note": "biệt 是重聲(nặng)，尾音短而下沉",
    "example": "Tạm biệt, hẹn gặp lại!",
    "example_zh": "再見，下次見！",
    "example_rom": "tam biet, hen gap lai!",
    "grammar_point": "hẹn gặp lại = 期待再相見（下次見的固定說法）"
  },
  {
    "id": "vi-0010",
    "lang": "vi",
    "region": "north",
    "type": "word",
    "topic": "自我介紹",
    "text": "vâng / dạ",
    "meaning_zh": "是的（禮貌回應；北部常用 vâng）",
    "romanization": "vung / za",
    "tone_note": "北部 d 和 gi 都發「z」音，dạ → 「za」；vâng 是北部日常說法",
